# GitHub Personal Access Token (used with GitHub Models inference endpoint)
GITHUB_TOKEN=ghp_...

# Qdrant Cloud URL (or http://localhost:6333 for local)
QDRANT_URL=https://your-cluster.qdrant.io

# Qdrant API key (only needed for Qdrant Cloud; omit for local)
QDRANT_API_KEY=your-qdrant-api-key

# Port (optional, defaults to 3000)
PORT=3000
